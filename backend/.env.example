# GenUI Backend Configuration - LOCAL DEV profile.
# Copy this file to .env and fill in your values.
#
# This is also the complete reference of every knob with its default.
# Deploying for a customer? Use deploy/customer.env.example instead (the
# production compose wires REDIS_URL/QDRANT_HOST itself and must never
# run with GENUI_DEV_OPEN). New settings get documented in BOTH files.

# Application
DEBUG=false
API_PREFIX=/api/v1

# LLM Configuration
LLM_PROVIDER=openai                     # openai | anthropic | gemini
OPENAI_API_KEY=your-openai-key
# OPENAI_BASE_URL=                      # custom OpenAI-compatible endpoint (Azure, vLLM, Ollama)
# ANTHROPIC_API_KEY=your-anthropic-key  # if LLM_PROVIDER=anthropic (pip install anthropic)
# GOOGLE_API_KEY=your-google-key        # if LLM_PROVIDER=gemini (uses Gemini's OpenAI-compatible API)

# Model Selection
RESPONSE_MODEL=gpt-5.4-mini
PROFILE_MODEL=gpt-4o-mini

# Embeddings (BYOK, like the LLM).
# Defaults inherit the LLM's OpenAI settings, 
# so an all-local OPENAI_BASE_URL keeps embeddings in-house too.
# fallback to api.openai.com.
EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_PROVIDER=openai   # openai (any OpenAI-compatible endpoint) | gemini
# EMBEDDING_API_KEY=          # defaults to OPENAI_API_KEY (GOOGLE_API_KEY for gemini)
# EMBEDDING_BASE_URL=         # vLLM/Ollama/TEI/RunPod endpoint; defaults to OPENAI_BASE_URL
# EMBEDDING_DIMENSIONS=       # vector size; unset = derived from the model

# Qdrant Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=genui_documents

# RAG Configuration
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=5
SIMILARITY_THRESHOLD=0.35

# Document Extraction (file uploads)
EXTRACTOR_BACKEND=local      # default: pypdf/docx/bs4, zero dependencies, data stays in-house
# EXTRACTOR_BACKEND=docling  # local upgrade, no GPU: better tables/layout + images (pip install docling)
# EXTRACTOR_BACKEND=glmocr   # state-of-the-art incl. scans (pip install glmocr)
# GLMOCR_BASE_URL=http://localhost:8080   # self-hosted GLM-OCR (vLLM/Ollama): data stays in-house
# GLMOCR_API_KEY=                         # Z.ai cloud API: documents LEAVE your infra, opt-in consciously

# Semantic Chunking
USE_SEMANTIC_CHUNKING=true
BREAKPOINT_PERCENTILE_THRESHOLD=95
BUFFER_SIZE=1

# Zone Render Cache (segment-based, stale-while-revalidate)
ZONE_CACHE_ENABLED=true
ZONE_CACHE_FRESH_TTL=300      # seconds served without revalidation
ZONE_CACHE_STALE_TTL=86400    # seconds served stale while refreshing in background
ZONE_CACHE_LOCK_TTL=60        # single-flight refresh lock duration
# REDIS_URL=redis://localhost:6379/0   # empty = in-memory fallback (single-process dev ONLY).
#   REQUIRED with --workers > 1: profiles, rate limits, metrics and the
#   single-flight render lock are cross-process state. On a Redis blip the
#   backend falls back to memory and reconnects with backoff (see /health).

# Profile Segmentation
SEGMENT_MIN_CONFIDENCE=0.5
SEGMENT_MAX_INTERESTS=3

# Output Guarantees
URL_WHITELIST_ENABLED=true       # only URLs present in the input survive in generated UI
NUMERIC_GROUNDING_ENABLED=true   # stat values, prices and chart points must trace to input numbers
# Per-tenant banned terms, enforced post-generation ("*" applies to every tenant).
# A component containing a banned term is dropped; chat text is redacted.
# CONTENT_POLICY={"*": {"banned_terms": ["free money"]}, "acme": {"banned_terms": ["guaranteed returns"]}}

# Authentication: comma-separated "key" or "key:tenant" entries.
# Without keys the API FAILS CLOSED (403) unless GENUI_DEV_OPEN=1 is set.
# Client keys ship to the browser (identify the app, gate rate limits);
# admin keys are server-to-server only.
# CLIENT_API_KEYS=pk_live_abc123:acme,pk_live_def456:globex
# ADMIN_API_KEYS=sk_live_xyz789:acme

# Explicit dev mode: run WITHOUT keys/user-token secrets (open API).
# Never set in production.
GENUI_DEV_OPEN=1

# Signed user identity ("secret:tenant" entries). Backend signs
# {user_id, tenant, exp} with this secret (auth.identity.sign_user_token)
# and the browser sends it as X-User-Token. Required in production for
# /profile and any personalized render carrying a user_id.
# USER_TOKEN_SECRETS=change-me-long-random:acme

# Rate Limiting (requests per minute per client key; 0 = disabled)
# A /zone/batch-render of N zones counts as N requests, not 1.
RATE_LIMIT_PER_MINUTE=120

# Cost controls: a public pk_ key must not convert traffic into LLM spend.
# LLM_BUDGET_PER_HOUR caps LLM generations per tenant per hour across all
# workers (cold misses, stale refreshes, cache-off renders; admin warmup
# and admin cache_strategy=live are exempt). Over the cap: cached renders
# keep being served, new generations return 429. SET THIS IN PRODUCTION.
# LLM_BUDGET_PER_HOUR=500
ZONE_BATCH_MAX=10                # max zones per batch-render request (413 above)
LLM_TIMEOUT_SECONDS=60           # per-call LLM/embedding timeout; empty = SDK default (10 min)

# Audit Log (what was shown to whom)
AUDIT_LOG_ENABLED=true
# Empty path (production default) = emit on the 'genui.audit' logger
# A file path is for single-worker runs; rotation is built in.
# AUDIT_LOG_PATH=./audit.jsonl
# AUDIT_LOG_MAX_BYTES=52428800   # rotate at 50 MB (0 = never)
# AUDIT_LOG_BACKUP_COUNT=5       # audit.jsonl.1 ... .5 kept

# Server-side Profiles
PROFILE_TTL_SECONDS=0            # retention; e.g. 7776000 = 90 days, 0 = forever

# Experimentation: measure personalization uplift vs control
HOLDOUT_PERCENT=0                # e.g. 10 = 10% of identified users get the generic render
HOLDOUT_SALT=genui-exp-1         # change to reshuffle arms (new experiment)

# Tracing (OpenTelemetry)
TRACING_ENABLED=false
# OTLP_ENDPOINT=http://localhost:4317   # empty = console exporter

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
