# GenUI Backend Configuration
# Copy this file to .env and fill in your values

# Application
DEBUG=false
API_PREFIX=/api/v1

# LLM Configuration
LLM_PROVIDER=openai                     # openai | anthropic | gemini
OPENAI_API_KEY=your-openai-key
# OPENAI_BASE_URL=                      # custom OpenAI-compatible endpoint (Azure, vLLM, Ollama)
# ANTHROPIC_API_KEY=your-anthropic-key  # if LLM_PROVIDER=anthropic (pip install anthropic)
# GOOGLE_API_KEY=your-google-key        # if LLM_PROVIDER=gemini (uses Gemini's OpenAI-compatible API)

# Model Selection
RESPONSE_MODEL=gpt-5.4-mini
PROFILE_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Qdrant Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=genui_documents
QDRANT_VECTOR_SIZE=1536

# RAG Configuration
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=5
SIMILARITY_THRESHOLD=0.35

# Document Extraction (file uploads): backend is configuration, not code
EXTRACTOR_BACKEND=local      # default: pypdf/docx/bs4, zero dependencies, data stays in-house
# EXTRACTOR_BACKEND=docling  # local upgrade, no GPU: better tables/layout + images (pip install docling)
# EXTRACTOR_BACKEND=glmocr   # state-of-the-art incl. scans (pip install glmocr)
# GLMOCR_BASE_URL=http://localhost:8080   # self-hosted GLM-OCR (vLLM/Ollama): data stays in-house
# GLMOCR_API_KEY=                         # Z.ai cloud API: documents LEAVE your infra, opt-in consciously

# Semantic Chunking
USE_SEMANTIC_CHUNKING=true
BREAKPOINT_PERCENTILE_THRESHOLD=95
BUFFER_SIZE=1

# Zone Render Cache (segment-based, stale-while-revalidate)
ZONE_CACHE_ENABLED=true
ZONE_CACHE_FRESH_TTL=300      # seconds served without revalidation
ZONE_CACHE_STALE_TTL=86400    # seconds served stale while refreshing in background
ZONE_CACHE_LOCK_TTL=60        # single-flight refresh lock duration
# REDIS_URL=redis://localhost:6379/0   # empty = in-memory cache (single process only)

# Profile Segmentation
SEGMENT_MIN_CONFIDENCE=0.5
SEGMENT_MAX_INTERESTS=3

# Output Guarantees
URL_WHITELIST_ENABLED=true   # only URLs present in the input survive in generated UI

# Authentication: comma-separated "key" or "key:tenant" entries.
# Without keys the API is OPEN (dev only!). Client keys ship to the browser
# (identify the app, gate rate limits); admin keys are server-to-server only.
# CLIENT_API_KEYS=pk_live_abc123:acme,pk_live_def456:globex
# ADMIN_API_KEYS=sk_live_xyz789:acme

# Rate Limiting (requests per minute per client key; 0 = disabled)
RATE_LIMIT_PER_MINUTE=120

# Audit Log (what was shown to whom)
AUDIT_LOG_ENABLED=true
# AUDIT_LOG_PATH=./audit.jsonl   # empty = emit on the 'genui.audit' logger

# Server-side Profiles
PROFILE_TTL_SECONDS=0            # retention; e.g. 7776000 = 90 days, 0 = forever

# Experimentation: measure personalization uplift vs control
HOLDOUT_PERCENT=0                # e.g. 10 = 10% of identified users get the generic render
HOLDOUT_SALT=genui-exp-1         # change to reshuffle arms (new experiment)

# Tracing (OpenTelemetry)
TRACING_ENABLED=false
# OTLP_ENDPOINT=http://localhost:4317   # empty = console exporter

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
