# =============================================================================
# GenUI deployment config — ONE file per customer deployment.
#
#   cp customer.env.example customer.env    (customer.env is gitignored)
#
# This file IS the customer parametrization: their LLM engine (BYOK), their
# tenants, their limits. Every knob of backend/config/settings.py can be set
# here; below is the minimum a production deployment must decide. The full
# knob reference (and the local-dev profile) is backend/.env.example.
# REDIS_URL / QDRANT_HOST are wired by docker-compose.yml — do not set them.
# =============================================================================

# --- LLM engine, BYOK: the CUSTOMER's engine and key (their bill) ------------
# Full matrix: deploy/README.md §Engine BYOK matrix
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-REPLACE-ME
# OPENAI_BASE_URL=http://vllm.internal:8000/v1  # any OpenAI-compatible: Azure/vLLM/Ollama/RunPod
# LLM_PROVIDER=anthropic  + ANTHROPIC_API_KEY=  # needs `anthropic` in the image (see Dockerfile)
# LLM_PROVIDER=gemini     + GOOGLE_API_KEY=
RESPONSE_MODEL=gpt-4o-mini
PROFILE_MODEL=gpt-4o-mini

# --- Embeddings, BYOK: documents embed where the customer chooses ------------
# Defaults inherit the OpenAI settings above, so an all-local OPENAI_BASE_URL
# keeps embeddings local too. Misconfiguration fails loudly at startup.
EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_PROVIDER=openai   # openai (any OpenAI-compatible endpoint) | gemini
# EMBEDDING_BASE_URL=         # defaults to OPENAI_BASE_URL
# EMBEDDING_API_KEY=          # defaults to OPENAI_API_KEY
# EMBEDDING_DIMENSIONS=       # unset = derived from the model

# --- Tenant declaration: the access architecture of THIS deployment ----------
# A tenant exists by appearing in these three vars (entry format "value:tenant").
# Example below: insurance portal with two tenants — `agente` (employee/agent
# portal) and `assicurato` (policyholder portal). Each tenant gets its own
# keys, its own user-identity secret, and with them its own isolated KB,
# profiles, cache, metrics, budget (see deploy/TENANT-ISOLATION.md).
# Generate values with: openssl rand -hex 24
CLIENT_API_KEYS=pk_REPLACE_agente:agente,pk_REPLACE_assicurato:assicurato
ADMIN_API_KEYS=sk_REPLACE_agente:agente,sk_REPLACE_assicurato:assicurato
USER_TOKEN_SECRETS=REPLACE-long-random-1:agente,REPLACE-long-random-2:assicurato

# --- Cost controls: protect the customer's LLM key from public-key traffic ---
LLM_BUDGET_PER_HOUR=500      # LLM generations per tenant per hour (429 above; cached renders keep serving)
RATE_LIMIT_PER_MINUTE=120    # requests per client key per minute
LLM_TIMEOUT_SECONDS=60       # per-call LLM/embedding timeout

# --- Capacity: uvicorn worker processes (see deploy/README.md §Sizing) -------
WORKERS=4

# --- CORS: the customer site origins that embed GenUI zones ------------------
CORS_ORIGINS=https://www.example-customer.com

# --- Data retention posture (GDPR): decided per customer ---------------------
AUDIT_LOG_ENABLED=true       # audit goes to the 'genui.audit' logger -> `docker compose logs backend`
PROFILE_TTL_SECONDS=7776000  # user profiles: 90 days, refreshed on write (0 = keep forever)

# --- Optional ---------------------------------------------------------------
# HOLDOUT_PERCENT=10         # measure personalization uplift vs a control arm
# TRACING_ENABLED=true       # OpenTelemetry; OTLP_ENDPOINT=http://collector:4317
# EXTRACTOR_BACKEND=local    # document extraction: local | docling | glmocr

# NEVER set GENUI_DEV_OPEN here. It disables authentication entirely and this
# file declares real tenants. Dev-only, and only outside customer deployments.
